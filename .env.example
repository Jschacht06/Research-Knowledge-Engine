POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=your_database_name
DATABASE_URL=postgresql+psycopg://your_postgres_user:replace_with_a_strong_password@db:5432/your_database_name
JWT_SECRET=replace_with_a_long_random_secret
STORAGE_DIR=/data/files
FRONTEND_ORIGINS=http://localhost:5173,http://frontend:5173
ALLOWED_EMAIL_DOMAINS=domain.com
AUTH_COOKIE_NAME=rke_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://backend:8000
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace_with_a_strong_password
